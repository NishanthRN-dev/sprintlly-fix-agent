#!/usr/bin/env node
const a = Object.fromEntries(
  process.argv.slice(2).reduce((acc, v, i, arr) =>
    v.startsWith('--') ? [...acc, [v.slice(2), arr[i + 1]]] : acc, []));

const res = await fetch(`${process.env.APP_URL}/api/public/report-step`, {
  method: 'POST',
  headers: {
    'content-type': 'application/json',
    authorization: `Bearer ${process.env.FIX_AGENT_TOKEN}`,
  },
  body: JSON.stringify({
    job_id:  process.env.JOB_ID,     // injected by the poller, never in the prompt
    step:    Number(a.step),
    status:  a.status,               // running | completed | failed
    summary: a.summary ?? null,
    error:   a.error ?? null,
  }),
});

if (!res.ok) { console.error('report-step failed:', res.status); process.exit(1); }